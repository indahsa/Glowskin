<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlowSkin - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-[#FFF8F6] text-[#4D6D6D] min-h-screen flex flex-col md:flex-row">

    <aside class="w-full md:w-64 bg-white border-b md:border-b-0 md:border-r border-[#FFE4E4] p-6 flex flex-col justify-between shrink-0">
        <div>
            <div class="flex items-center gap-2 mb-8">
                <span class="text-2xl">✨</span>
                <h3 class="text-xl font-bold text-[#E8A0A0] tracking-wider">GlowSkin</h3>
            </div>
            <nav class="space-y-1.5">
                <a class="flex items-center gap-3 px-4 py-3 text-sm font-bold rounded-xl bg-[#FFD9D9] text-[#333333] transition" href="/">
                    <i class="fa-solid fa-chart-pie text-lg w-5"></i> Dashboard
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-[#FFF0F0] hover:text-[#E8A0A0] transition" href="/tracker">
                    <i class="fa-solid fa-calendar-check text-lg w-5"></i> Routine Tracker
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-[#FFF0F0] hover:text-[#E8A0A0] transition" href="/diary">
                    <i class="fa-solid fa-book-open-reader text-lg w-5"></i> Skin Diary
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-[#FFF0F0] hover:text-[#E8A0A0] transition" href="/recommendations">
                    <i class="fa-solid fa-sparkles text-lg w-5"></i> Recommendations
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-[#FFF0F0] hover:text-[#E8A0A0] transition" href="/articles">
                    <i class="fa-solid fa-newspaper text-lg w-5"></i> Articles
                </a>
            </nav>
        </div>
        <div class="mt-8">
            <a href="/logout" class="flex items-center justify-center gap-2 w-full py-2.5 text-xs font-bold text-red-500 bg-red-50 hover:bg-red-100 rounded-xl transition">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Keluar App
            </a>
        </div>
    </aside>

    <main class="flex-1 p-6 md:p-10 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Hi, <%= user.name %>! ☀️</h1>
            <p class="text-gray-400 text-sm mt-1">Mari rawat pesona dan kesehatan kulitmu hari ini!</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
            <div class="bg-white p-5 rounded-2xl border border-[#FFE4E4] shadow-sm flex flex-col justify-between min-h-[140px]">
                <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Skin Condition</span>
                <span class="text-xl font-bold text-[#E8A0A0] my-2"><%= status.skin_condition %></span>
                <form action="/update-condition" method="POST" class="flex gap-2">
                    <select name="skin_condition" class="text-xs bg-gray-50 border border-gray-200 rounded-lg p-1.5 focus:outline-none">
                        <option value="Normal Skin" <%= status.skin_condition === 'Normal Skin' ? 'selected' : '' %>>Normal</option>
                        <option value="Oily Skin" <%= status.skin_condition === 'Oily Skin' ? 'selected' : '' %>>Oily</option>
                        <option value="Dry Skin" <%= status.skin_condition === 'Dry Skin' ? 'selected' : '' %>>Dry</option>
                        <option value="Acne Prone" <%= status.skin_condition === 'Acne Prone' ? 'selected' : '' %>>Acne Prone</option>
                    </select>
                    <button type="submit" class="text-xs font-bold text-white bg-[#E8A0A0] px-2 py-1 rounded-lg hover:bg-[#FFAAAA]">Set</button>
                </form>
            </div>

            <div class="bg-white p-5 rounded-2xl border border-[#FFE4E4] shadow-sm flex flex-col justify-between min-h-[140px]">
                <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Mood Today</span>
                <div class="my-1">
                    <div class="text-lg"><%= status.mood_emoji %></div>
                    <span class="text-sm font-bold text-gray-700">Status: <%= status.mood %></span>
                </div>
                <form action="/update-mood" method="POST" class="flex gap-2">
                    <select name="mood" class="text-xs bg-gray-50 border border-gray-200 rounded-lg p-1.5 focus:outline-none">
                        <option value="Good" <%= status.mood === 'Good' ? 'selected' : '' %>>Good</option>
                        <option value="Happy" <%= status.mood === 'Happy' ? 'selected' : '' %>>Happy</option>
                        <option value="Tired" <%= status.mood === 'Tired' ? 'selected' : '' %>>Tired</option>
                        <option value="Stressed" <%= status.mood === 'Stressed' ? 'selected' : '' %>>Stressed</option>
                    </select>
                    <button type="submit" class="text-xs font-bold text-white bg-[#E8A0A0] px-2 py-1 rounded-lg hover:bg-[#FFAAAA]">Set</button>
                </form>
            </div>

            <div class="bg-white p-5 rounded-2xl border border-[#FFE4E4] shadow-sm flex flex-col justify-between min-h-[140px]">
                <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Water Intake Tracker 💧</span>
                <span class="text-lg font-bold text-gray-700 my-1"><%= status.glasses %> / 8 Gelas</span>
                <div class="flex gap-2">
                    <form action="/add-water" method="POST" class="flex-1">
                        <button type="submit" class="w-full py-1.5 bg-blue-50 text-blue-600 font-bold text-xs rounded-xl hover:bg-blue-100 transition">+ Minum</button>
                    </form>
                    <form action="/reset-water" method="POST">
                        <button type="submit" class="px-3 py-1.5 bg-gray-50 text-gray-400 font-bold text-xs rounded-xl hover:bg-gray-100 transition">Reset</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-[#FFE4E4] shadow-sm overflow-hidden">
            <div class="p-5 border-b border-[#FFE4E4] flex justify-between items-center bg-gray-50">
                <h3 class="font-bold text-gray-800 text-md">Progress Rutinitas Hari Ini</h3>
                <span class="text-xs font-bold text-[#E8A0A0] bg-[#FFF0F0] px-3 py-1 rounded-full">
                    <%= completedRoutines %> / <%= routines.length %> Selesai
                </span>
            </div>
            <div class="divide-y divide-gray-100">
                <% if (routines.length === 0) { %>
                    <div class="p-8 text-center text-gray-400 text-sm">Belum ada jadwal rutinitas. Yuk buat di menu Routine Tracker!</div>
                <% } else { %>
                    <% routines.forEach(routine => { %>
                        <div class="p-4 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <form action="/toggle-routine/<%= routine.id %>" method="POST">
                                    <button type="submit" class="text-xl transition">
                                        <% if (routine.completed === 1) { %>
                                            <i class="fa-solid fa-square-check text-green-500"></i>
                                        <% } else { %>
                                            <i class="fa-regular fa-square text-gray-300 hover:text-[#E8A0A0]"></i>
                                        <% } %>
                                    </button>
                                </form>
                                <span class="text-sm <%= routine.completed === 1 ? 'line-through text-gray-300' : 'text-gray-700 font-medium' %>">
                                    <%= routine.step %>
                                </span>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>