<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlowSkin - Recommendations</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-[#FFF8F6] p-4 sm:p-8 text-[#4D6D6D]">
    <div class="max-w-2xl mx-auto bg-white p-6 rounded-3xl border border-[#FFE4E4] shadow-sm mt-6">
        <a href="/" class="inline-flex items-center gap-2 text-xs font-bold text-[#E8A0A0] hover:underline mb-4">
            <i class="fa-solid fa-arrow-left"></i> Kembali ke Dashboard
        </a>
        
        <div class="text-center mb-6">
            <h3 class="text-xl font-bold text-gray-800">✨ Smart Recommendations</h3>
            <p class="text-xs text-gray-400 mt-0.5">Rekomendasi bahan aktif perawatan personal sesuai jenis kulitmu</p>
        </div>

        <div class="bg-[#FFF0F0] text-center py-3 rounded-2xl border border-[#FFE4E4] text-sm font-bold text-gray-800 mb-6">
            Kondisi Kulit Terdeteksi: <span class="text-red-500 font-extrabold px-1"><%= condition %></span>
        </div>

        <div class="space-y-6">
            <div>
                <h5 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-3">🧪 Kandungan Bahan yang Disarankan</h5>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <% recommendation.ingredients.forEach(function(ing) { %>
                        <div class="p-3.5 bg-gray-50 rounded-2xl border border-gray-100 flex items-center gap-3">
                            <span class="text-xl">🌟</span>
                            <span class="text-sm font-bold text-gray-700"><%= ing %></span>
                        </div>
                    <% }); %>
                </div>
            </div>

            <div>
                <h5 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-3">🛍️ Contoh Jenis Produk Pendukung</h5>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <% recommendation.products.forEach(function(prod) { %>
                        <div class="p-3.5 bg-white rounded-2xl border border-[#FFE4E4] flex items-center gap-3">
                            <span class="text-xl">🧴</span>
                            <span class="text-sm font-medium text-gray-700"><%= prod %></span>
                        </div>
                    <% }); %>
                </div>
            </div>

            <div class="p-4 bg-[#FFFBFB] border-l-4 border-red-300 rounded-r-2xl text-xs leading-relaxed text-gray-600">
                <strong class="text-gray-800 block mb-1 text-sm">💡 Tips Tambahan:</strong>
                <%= recommendation.tips %>
            </div>
        </div>
    </div>
</body>
</html>